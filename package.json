{
  "name": "code-cleaner",
  "version": "0.7.1",
  "description": "This code cleaner app is a code cleaning automation tool designed to format and log errors for the markup used to build courses with the PimaOnline Themepack.",
  "main": "index.js",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "npm": "please-use-pnpm",
    "pnpm": "11.1.2"
  },
  "scripts": {
    "dev": "gulp",
    "start": "gulp clean-copy && gulp log && gulp check-image-sizes",
    "log": "gulp log && gulp check-image-sizes",
    "clean": "gulp clean-copy",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js"
  },
  "author": "Francisco Reynoso",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "gulp": "^5.0.1",
    "gulp-cli": "^3.1.0",
    "gulp-filter": "^9.0.1",
    "gulp-jsbeautifier": "^3.0.1",
    "gulp-size": "^5.0.0",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.14",
    "through2": "^4.0.2"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.5",
    "multer": "^2.1.1"
  }
}
